PORT=3333
APP_URL=http://localhost:3000

# Neon/Postgres. Copie a connection string do painel da Neon.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Use uma string longa e aleatoria em producao.
JWT_SECRET="troque-por-uma-chave-grande"
JWT_EXPIRES_IN="3h"

# Recuperacao de senha por codigo enviado por email.
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_RESEND_SECONDS=60
PASSWORD_RESET_MAX_ATTEMPTS=5

# Intervalo minimo para reenviar email de alerta quando um aparelho nao autorizado tenta acessar.
DEVICE_BLOCK_ALERT_INTERVAL_MINUTES=60

# Defina um segredo e configure o mesmo valor no webhook da Cakto, se ela permitir header/secret.
CAKTO_WEBHOOK_SECRET="troque-por-um-segredo-do-webhook"
ADMIN_IMPORT_SECRET="troque-por-um-segredo-para-importacao"

# Produto esperado. Opcional, mas recomendado para nao liberar produto errado.
CAKTO_PRODUCT_NAME="Pack do Criador"
CAKTO_CLIENT_ID="client-id-da-cakto"
CAKTO_CLIENT_SECRET="client-secret-da-cakto"

# Link publico de checkout. Por padrao, a cada 3 vendas/usuarios no link afiliado,
# a proxima pessoa recebe o link proprio, e o ciclo reinicia.
CHECKOUT_AFFILIATE_URL="https://pay.cakto.com.br/wjzbfzc_596335?affiliate=6daZPhsr"
CHECKOUT_OWN_URL="https://pay.cakto.com.br/wjzbfzc_596335"
CHECKOUT_AFFILIATE_SALES_BEFORE_OWN=3
# Use "purchases" para contar compras registradas ou "users" para contar usuarios com acesso.
CHECKOUT_ROTATION_SOURCE=purchases

# SMTP transacional. Exemplo abaixo usando Brevo.
# No Brevo, use a SMTP key, nao a API key nem a senha da sua conta.
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER="seu-login-smtp-da-brevo"
SMTP_PASS="sua-smtp-key-da-brevo"
MAIL_FROM="Pack do Criador <acesso@seudominio.com>"
SUPPORT_EMAIL="packdocriador1@gmail.com"

# Storage das figurinhas.
# Em producao, prefira Cloudflare R2 para nao perder arquivos em deploy/restart.
STICKER_STORAGE_DRIVER=local
STICKER_STORAGE_DIR="./.private/stickers"
STICKER_UPLOAD_MAX_IMAGE_MB=20
STICKER_UPLOAD_MAX_FILES=1000
STICKER_UPLOAD_MAX_REQUEST_MB=512
# Limite total de storage controlado pelo backend. Use 9500 para travar perto de 9.5GB.
# Deixe 0 ou vazio para desativar a trava.
STICKER_STORAGE_MAX_MB=9500

# Cloudflare R2. Use quando STICKER_STORAGE_DRIVER=r2.
R2_ACCOUNT_ID="account-id-da-cloudflare"
R2_BUCKET="nome-do-bucket-r2"
R2_ACCESS_KEY_ID="access-key-id-do-token-r2"
R2_SECRET_ACCESS_KEY="secret-access-key-do-token-r2"
# Opcional. Se nao informar, usa https://R2_ACCOUNT_ID.r2.cloudflarestorage.com
# R2_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"

# Na Vercel, requests para Functions sao limitados pela plataforma a 4.5MB.
# Use 4MB quando este backend estiver hospedado na Vercel ou envie lotes menores pelo frontend.
# STICKER_UPLOAD_MAX_IMAGE_MB=4
# STICKER_UPLOAD_MAX_REQUEST_MB=4
